{
  "name": "flowone-drive",
  "version": "2.4.4",
  "description": "Desktop sync client for FlowOne Drive - sync your files like Google Drive",
  "main": "dist/main/index.js",
  "author": "FlowOne",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:preload\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:preload": "tsc -p tsconfig.preload.json --watch",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "generate-icons": "node scripts/generate-icons.js"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "axios": "^1.6.5",
    "better-sqlite3": "^11.10.0",
    "chokidar": "^3.5.3",
    "crypto-js": "^4.2.0",
    "electron-store": "^8.1.0",
    "express": "^5.2.1",
    "get-windows": "^9.3.0",
    "net-snmp": "^3.26.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.1",
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.5",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^5.0.3",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "pinia": "^2.1.7",
    "postcss": "^8.4.33",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vue": "^3.4.15"
  }
}
