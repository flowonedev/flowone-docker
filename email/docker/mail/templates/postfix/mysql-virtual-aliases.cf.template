# Postfix virtual aliases MySQL map — FlowOne Docker mail pod
# Rendered from: {{MAIL_DB_HOST}}, {{MAIL_DB_PORT}}, {{MAIL_DB_USER}}, {{MAIL_DB_PASS}}, {{MAIL_DB_NAME}}
user = {{MAIL_DB_USER}}
password = {{MAIL_DB_PASS}}
hosts = {{MAIL_DB_HOST}}:{{MAIL_DB_PORT}}
dbname = {{MAIL_DB_NAME}}

# Returns the forward destination(s) for a source address (comma-separated allowed).
query = SELECT destination FROM mail_forwards WHERE source_email='%s' AND status='active'
