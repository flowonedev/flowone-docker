# FlowOne per-server stack configuration (Phase B production compose).
#
# Copy to `.env` and fill in per host. The Fleet engine renders this file per
# server; everything here is INJECTED at runtime (never baked into the image).
# Service hostnames use compose service names on the internal bridge network.

# ---- Identity / URLs ----
EMAIL_DOMAIN=email.example.com
FRONTEND_URL=https://email.example.com
API_URL=https://email.example.com/api
APP_ENV=prod
APP_DEBUG=false
# TLS: 1 wires a :443 listener + vhssl{} using the certs below (default
# /etc/letsencrypt/live/$EMAIL_DOMAIN/...). Mount /etc/letsencrypt into the web
# container when enabling. Leave 0 for an HTTP-only bring-up.
ENABLE_SSL=0
# SSL_CERT_FILE=/etc/letsencrypt/live/email.example.com/fullchain.pem
# SSL_KEY_FILE=/etc/letsencrypt/live/email.example.com/privkey.pem

# ---- App database (shared devc_vps_dash) ----
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=devc_vps_dash
DB_USER=vpsadmin
DB_PASS=change-me

# ---- Mail database (Dovecot/Postfix virtual users) ----
MAIL_DB_HOST=mariadb
MAIL_DB_NAME=mailserver
MAIL_DB_USER=mailuser
MAIL_DB_PASS=change-me

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ---- Meilisearch ----
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=change-me
MEILI_SEARCH_KEY=change-me

# ---- Crypto / secrets (MIGRATE byte-for-byte; regenerating bricks data) ----
# JWT: backend signs with the private key; mailsync + collab verify with public.
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY_PATH=/var/www/vps-email/backend/storage/config/jwt-private.pem
JWT_PUBLIC_KEY_PATH=/var/www/vps-email/backend/storage/config/jwt-public.pem
IMAP_ENCRYPTION_KEY=change-me-never-rotate
AI_ENCRYPTION_KEY=change-me
# OAUTH_KEYS is the versioned encryption key map; OAUTH_CURRENT_VERSION selects active.
OAUTH_KEYS=
OAUTH_CURRENT_VERSION=1
SSO_SERVER_KEY=change-me

# ---- Realtime services (compose service names) ----
# OLS proxies /collab-ws and /mailsync_ws to these on the bridge network.
COLLAB_ADDR=collab:1234
MAILSYNC_ADDR=mailsync:1235
COLLAB_WS_URL=wss://email.example.com/collab-ws

# ---- Calls: coTURN + LiveKit ----
STUN_URL=stun:turn.example.com:3478
TURN_URL=turn:turn.example.com:3478
TURN_SECRET=change-me
TURN_TTL=86400
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# REQUIRED when LiveKit creds are set (stunnel TLS port). Provisioning fails loudly if blank.
LIVEKIT_WS_URL=wss://email.example.com:7443

# ---- Push (web) ----
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ---- Panel agent ----
PANEL_API_URL=https://panel.example.com/api
PANEL_API_KEY=

# ---- OAuth providers (optional) ----
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# ---- MariaDB container bootstrap (only used by the db service) ----
MYSQL_ROOT_PASSWORD=change-me
