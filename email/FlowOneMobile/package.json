{
  "name": "flowone-mobile",
  "version": "2.0.0",
  "description": "FlowOne Pro mobile app - Email, Calendar, Boards, Drive, Chat",
  "author": "FlowOne",
  "license": "MIT",
  "scripts": {
    "build:web": "cd ../frontend && npm run build",
    "sync:ios": "npx cap sync ios",
    "sync:android": "npx cap sync android",
    "open:ios": "npx cap open ios",
    "open:android": "npx cap open android",
    "build:ios": "npm run build:web && npm run sync:ios",
    "build:android": "npm run build:web && npm run sync:android",
    "dev:ios": "npm run build:web && npx cap run ios",
    "dev:android": "npm run build:web && npx cap run android"
  },
  "dependencies": {
    "@capacitor-firebase/messaging": "6.1.0",
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.0",
    "@capacitor/browser": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/device": "^6.0.3",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@capawesome/capacitor-badge": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "typescript": "^5.9.3"
  }
}
