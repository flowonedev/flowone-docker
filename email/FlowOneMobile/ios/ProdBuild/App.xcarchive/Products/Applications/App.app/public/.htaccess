RewriteEngine On
RewriteBase /

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Set proper MIME types for JavaScript modules
<IfModule mod_mime.c>
    AddType application/javascript .js .mjs
    AddType text/css .css
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    
    # CORS for font files (required for srcdoc iframes with origin null)
    <FilesMatch "\.(woff|woff2|ttf|eot|otf)$">
        Header set Access-Control-Allow-Origin "*"
    </FilesMatch>

    # Cache static assets aggressively (they have hashes in filenames)
    <FilesMatch "\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    
    # Don't cache HTML (always get fresh version)
    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
</IfModule>

# Serve static privacy/terms pages directly (required for Google OAuth verification)
RewriteRule ^privacy/?$ /privacy/index.html [L]
RewriteRule ^terms/?$ /terms/index.html [L]

# CRITICAL: Do NOT rewrite requests for static assets to index.html
# Only rewrite navigation requests (no file extension or specific frontend routes)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|map|json|webmanifest)$
RewriteRule ^(.*)$ /index.html [L]

# Return 404 for missing static assets instead of index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|map)$
RewriteRule ^ - [R=404,L]

