{
	"appId": "com.flowone.pro",
	"appName": "FlowOne Pro",
	"webDir": "../frontend/dist",
	"server": {
		"androidScheme": "https",
		"iosScheme": "https",
		"allowNavigation": [
			"flowone.pro",
			"*.flowone.pro"
		]
	},
	"plugins": {
		"CapacitorHttp": {
			"enabled": true
		},
		"PushNotifications": {
			"presentationOptions": [
				"badge",
				"sound",
				"alert"
			]
		},
		"Keyboard": {
			"resize": "native",
			"resizeOnFullScreen": true
		},
		"StatusBar": {
			"style": "dark",
			"backgroundColor": "#1c1c22"
		}
	},
	"packageClassList": [
		"FirebaseMessagingPlugin",
		"AppPlugin",
		"CAPBrowserPlugin",
		"DevicePlugin",
		"HapticsPlugin",
		"KeyboardPlugin",
		"PushNotificationsPlugin",
		"StatusBarPlugin",
		"BadgePlugin"
	]
}
