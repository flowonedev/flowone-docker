# Copy to .env and fill in. NEVER commit real credentials.

# Base URL of the deployed FlowOne instance (no trailing slash)
FLOWONE_BASE_URL=https://flowone.pro

# Admin user used by the orchestrator to create rooms / portal calls.
# This account is used purely for provisioning fixtures.
FLOWONE_ADMIN_EMAIL=qa-admin@flowone.pro
FLOWONE_ADMIN_PASSWORD=replace-me

# CRM client id to attach portal-call fixtures to (must exist for ADMIN_EMAIL)
FLOWONE_CRM_CLIENT_ID=

# --- 2FA handling (only if the admin account has 2FA enabled) ---
#
# Provide ONE of the following. The suite tries device-token first (fastest),
# then explicit code, then computes from secret.
#
# After the first successful run with FLOWONE_2FA_CODE or FLOWONE_2FA_SECRET,
# the suite prints a FLOWONE_DEVICE_TOKEN value you can paste here to skip
# 2FA entirely on subsequent runs.
FLOWONE_DEVICE_TOKEN=
FLOWONE_2FA_CODE=
FLOWONE_2FA_SECRET=

# Optional: skip provisioning if you want to point the suite at a pre-existing room
# (set both to use this; leave blank to provision per-scenario)
FLOWONE_GUEST_TOKEN=
FLOWONE_ADMIN_TOKEN=

# Optional: explicit LiveKit ws URL for assertions; auto-discovered if blank
LIVEKIT_WS_URL=
