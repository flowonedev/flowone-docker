# =============================================================================
# FlowOne Email App - Environment Configuration
# Copy this file to .env and fill in the values for your environment.
# All secrets MUST be set via environment variables - never commit real values.
# =============================================================================

# --- Database ---
DB_HOST=127.0.0.1
DB_NAME=devc_vps_dash
DB_USER=vpsadmin
DB_PASS=CHANGE_ME

# --- Mail Server Database (Dovecot/Postfix) ---
MAIL_DB_HOST=127.0.0.1
MAIL_DB_NAME=vmail
MAIL_DB_USER=vmail
MAIL_DB_PASS=

# --- JWT ---
# Generate with: php -r "echo bin2hex(random_bytes(64));"
JWT_SECRET=CHANGE_ME

# --- SMTP (system notifications) ---
SMTP_NOTIFICATION_PASSWORD=

# --- Google OAuth ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Microsoft OAuth ---
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# --- Panel Integration ---
PANEL_API_URL=https://panel.devcon1.hu/api
PANEL_API_KEY=CHANGE_ME

# --- AI Encryption ---
AI_ENCRYPTION_KEY=

# --- Redis ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# --- Meilisearch ---
MEILI_HOST=http://127.0.0.1:7700
MEILI_MASTER_KEY=CHANGE_ME
MEILI_SEARCH_KEY=CHANGE_ME

# --- Web Push (VAPID) ---
# Generate with: cd mailsync/server && node ../../scripts/generate-vapid-keys.js
# Only the public key is served by the backend (/push/vapid-key); the private
# key is used by the mailsync server to send web pushes.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com

# --- Voice/Video Calls (LiveKit SFU) ---
# REQUIRED secrets for issuing LiveKit room tokens. There are NO source-code
# defaults: if these are unset, call token requests fail with "LiveKit API
# credentials not configured" (CallService::getLiveKitToken). If a secret is
# ever exposed, ROTATE it on the LiveKit server and update this value.
LIVEKIT_API_KEY=CHANGE_ME
LIVEKIT_API_SECRET=CHANGE_ME
LIVEKIT_WS_URL=wss://email.yourdomain.com:7443

# --- Legacy TURN/STUN (Coturn) — only used by GET /call/ice-servers (huddles) ---
# Calls use LiveKit (above); leave TURN_SECRET empty to disable TURN credentials.
STUN_URL=stun:stun.yourdomain.com:3478
TURN_URL=turn:turn.yourdomain.com:3478
TURN_SECRET=
TURN_TTL=86400

# --- Collaborative Editing ---
COLLAB_WS_PORT=1234
COLLAB_WS_HOST=localhost
COLLAB_WS_URL=wss://email.yourdomain.com/collab_ws

# --- Markets data (News dashboard "Market Overview" card) ---
# Free key from https://twelvedata.com/register (Basic plan: 800 calls/day).
# Leave empty to hide the stocks card; crypto (CoinGecko) keeps working
# without any key.
TWELVEDATA_API_KEY=
# Seconds to cache one basket before re-fetching upstream. 3600 = 1 hour.
MARKETS_CACHE_TTL=3600

# --- Debug ---
APP_DEBUG=false
