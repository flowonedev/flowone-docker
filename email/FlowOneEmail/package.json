{
  "name": "flowone-email",
  "version": "2.0.0",
  "description": "Offline-first desktop client for FlowOne - Email, Calendar, Boards, Drive",
  "main": "dist/main/index.js",
  "author": "FlowOne",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:preload\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:preload": "tsc -p tsconfig.preload.json --watch",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json && node -e \"require('fs').mkdirSync('dist/main/database',{recursive:true});require('fs').copyFileSync('src/main/database/schema.sql','dist/main/database/schema.sql')\"",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "generate-icons": "node scripts/generate-icons.js"
  },
  "dependencies": {
    "@hocuspocus/provider": "^2.13.0",
    "@tiptap/extension-collaboration": "^2.1.0",
    "@tiptap/extension-collaboration-cursor": "^2.1.0",
    "@tiptap/extension-color": "^2.27.2",
    "@tiptap/extension-font-family": "^2.27.2",
    "@tiptap/extension-highlight": "^2.27.2",
    "@tiptap/extension-image": "^2.1.0",
    "@tiptap/extension-link": "^2.1.0",
    "@tiptap/extension-placeholder": "^2.1.0",
    "@tiptap/extension-subscript": "^2.27.2",
    "@tiptap/extension-superscript": "^2.27.2",
    "@tiptap/extension-table": "^2.1.0",
    "@tiptap/extension-table-cell": "^2.1.0",
    "@tiptap/extension-table-header": "^2.1.0",
    "@tiptap/extension-table-row": "^2.1.0",
    "@tiptap/extension-text-align": "^2.1.0",
    "@tiptap/extension-text-style": "^2.27.2",
    "@tiptap/extension-underline": "^2.1.0",
    "@tiptap/pm": "^2.1.0",
    "@tiptap/starter-kit": "^2.1.0",
    "@tiptap/vue-3": "^2.1.0",
    "apexcharts": "^5.3.6",
    "axios": "^1.6.5",
    "diff": "^8.0.3",
    "docx": "^8.5.0",
    "dompurify": "^3.3.1",
    "electron-store": "^8.1.0",
    "express": "^4.18.2",
    "jszip": "^3.10.1",
    "livekit-client": "^2.17.1",
    "mammoth": "^1.11.0",
    "opentype.js": "^1.3.4",
    "perfect-freehand": "^1.2.3",
    "pinia": "^2.1.7",
    "polygon-clipping": "^0.15.7",
    "pptxgenjs": "^3.12.0",
    "sql.js": "^1.10.2",
    "uuid": "^9.0.1",
    "vue": "^3.4.15",
    "vue-i18n": "^11.2.8",
    "vue-router": "^4.2.5",
    "vue3-apexcharts": "^1.10.0",
    "vue3-emoji-picker": "^1.1.8",
    "ws": "^8.16.0",
    "xlsx": "^0.18.5",
    "y-indexeddb": "^9.0.12",
    "yjs": "^13.6.10"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/sql.js": "^1.4.9",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-vue": "^5.0.3",
    "@vueuse/core": "^10.7.2",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "electron-updater": "^6.1.7",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.33",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  }
}
