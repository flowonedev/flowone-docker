# Node
node_modules/

# Build outputs
dist/
build/
release/
out/

# Electron
*.exe
*.dmg
*.asar
win-unpacked/
mac-unpacked/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
storage/logs/

# Runtime-generated user data (avatars, drive uploads, mood boards)
email/backend/storage/avatars/
email/backend/storage/drive/
email/backend/storage/mood-uploads/
email/backend/storage/tmp/

# Composer dependencies (regenerated by `composer install` at build time)
email/backend/vendor/
fleet/api/vendor/
vendor/

# Mobile build artifacts
*.apk
*.aab
*.ipa

# Env
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Local dev overrides (never commit, never upload to server)
email/backend/src/config.local.php
email/backend/storage/config/jwt-private.pem
email/backend/storage/config/jwt-public.pem
# Fleet Manager local config (holds DB creds + GHCR registry token on the master)
fleet/api/config.local.php

# Ad-hoc deploy/recon scripts staged locally (may contain credentials) — never commit
.deploy-tmp/
email/docker/.deploy-tmp/

# Secrets — never commit
# APNs auth keys (.p8): upload to Firebase Console, then store offline (e.g. password manager)
*.p8
# Firebase Admin service account (server-side FCM credential)
fcm-service-account.json

# Test run logs (mailsync server test suites)
email/mailsync/server/logs/