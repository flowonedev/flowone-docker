# Enforce LF for text so shell scripts/configs run under bash regardless of
# the editing OS (these scripts are authored on Windows, run on Linux).
* text=auto eol=lf

*.sh   text eol=lf
*.php  text eol=lf
*.sql  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.conf text eol=lf
*.env  text eol=lf

# Binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff  binary
*.woff2 binary
*.ttf  binary
*.gz   binary
*.zip  binary
*.tar  binary
*.pdf  binary
